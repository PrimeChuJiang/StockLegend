[node name="RulesLabel" type="RichTextLabel" parent="VBox/MiddleArea/LeftPanel"]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 13
bbcode_enabled = true
text = "[b]== 规则 ==[/b]
[color=yellow]目标:[/color] 10回合后占格多者胜
[color=yellow]发表文章:[/color] 1行动点+2~4张牌
叠放卡牌,重叠部分生效
威力 = 重叠层数 - 1
[color=yellow]格子结算:[/color]
 中立格→占领(忠诚度=威力)
 己方格→忠诚度+威力
 敌方格→忠诚度-威力
 归零后继续打→翻色
[color=yellow]回合:[/color] 抽牌→玩家→AI→弃牌

[b]== 操作 ==[/b]
[color=cyan]点击卡牌[/color] 选中/取消(2~4张)
[color=cyan]WASD[/color] 移动激活卡牌
[color=cyan]R[/color] 旋转激活卡牌
[color=cyan]Tab[/color] 切换激活卡牌
[color=cyan]Q[/color] 整体旋转重叠图案
[color=cyan]点击棋盘[/color] 放置"
fit_content = true
scroll_active = false

